!/patchers/
!/patchers/**
!/score/
!/score/**
!/audio/
!audio/**

# Whitelist specific file
!/ONLINE_main.maxpat
!/ONLINE_main_2.maxpat
!/config.json
!/.gitignore
!/.gitattributes
!/score.txt