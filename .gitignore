# Ignore everything by default
*

.DS_Store

# Keep folders themselves (needed so Git can descend)
!*/

# Whitelist specific folders
!/patchers/
!/patchers/**
!/score/
!/score/**
!/audio/
!audio/**

# Whitelist specific file
!/ONLINE_main.maxpat
!/ONLINE_main_2.maxpat
!/config.json
!/.gitignore
!/.gitattributes
!/score.txt
!/network_scanner.py
!/run_scanner.command

# Ignore the active config in the performers folder
/patchers/performers/config.json

# Whitelist the template so others can see it
!/patchers/performers/config.example.json